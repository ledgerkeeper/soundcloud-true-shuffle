{
  "compilerOptions": {
    "allowJs": false,
    "checkJs": false,
    "declaration": false,
    "esModuleInterop": false,
    "exactOptionalPropertyTypes": false,
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "module": "None",
    "noEmitOnError": true,
    "noImplicitAny": false,
    "outDir": "dist",
    "removeComments": false,
    "rootDir": ".",
    "skipLibCheck": true,
    "sourceMap": false,
    "strict": false,
    "target": "ES2022",
    "types": ["chrome"],
    "useDefineForClassFields": true
  },
  "include": ["src/**/*.ts"],
  "exclude": ["dist", "node_modules", ".omx", ".codex"]
}
